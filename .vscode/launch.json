  "version": "0.2.0",
  "configurations": [
    {
      "name": "POS System (Dev - Android)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--flavor",
        "dev",
        "--target",
        "lib/main.dart",
        "--dart-define=appFlavor=dev",
        "--dart-define=logLevel=debug"
      ]
    },
    {
      "name": "POS System (Prod - Android)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--flavor",
        "prod",
        "--target",
        "lib/main.dart",
        "--dart-define=appFlavor=prod",
        "--dart-define=logLevel=info"
      ]
    },
    {
      "name": "POS System (Dev - iOS)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--flavor",
        "dev",
        "--target",
        "lib/main.dart",
        "--dart-define=appFlavor=dev",
        "--dart-define=logLevel=debug"
      ]
    },
    {
      "name": "POS System (Prod - iOS)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--flavor",
        "prod",
        "--target",
        "lib/main.dart",
        "--dart-define=appFlavor=prod",
        "--dart-define=logLevel=info"
      ]
    }
  ]
}
